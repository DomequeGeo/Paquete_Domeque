nitro_idw <- function(df, raster_base){
gs <- gstat::gstat(
formula = nitrogeno_suelo ~ 1,
locations = ~ x + y,
data = df,
nmax = 15,
set = list(idp = 2)
)
idw <- terra::interpolate(raster_base, gs)
idw <- terra::mask(idw, raster_base)
return(idw)
}
